<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f9fafb;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;">
  <div style="width:100%;max-width:24rem;padding:1.5rem;box-sizing:border-box;">
    <h1 style="text-align:center;font-size:1.75rem;font-weight:700;color:#111827;margin:0 0 1.5rem;">
      <%= SicoobSso.config.app_name.presence || "Entrar" %>
    </h1>

    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:.5rem;box-shadow:0 1px 3px rgba(0,0,0,.1);padding:1.5rem;text-align:center;">
      <div style="width:2.5rem;height:2.5rem;margin:0 auto 1rem;border:3px solid #e5e7eb;border-top-color:#2563eb;border-radius:50%;animation:sicoob-spin 1s linear infinite;"></div>
      <h2 style="font-size:1.125rem;font-weight:600;color:#111827;margin:0 0 .5rem;">Aprove o acesso no Tools</h2>
      <p id="sicoob-sso-msg" style="font-size:.875rem;color:#6b7280;margin:0;">
        Enviamos um pedido de aprovação. Abra o Tools e confirme para continuar…
      </p>
    </div>
  </div>
</div>

<style>@keyframes sicoob-spin { to { transform: rotate(360deg); } }</style>

<script>
  (function () {
    var pollUrl = "<%= sso_poll_path %>";
    var loginUrl = "<%= login_path %>";
    var maxAttempts = 90; // ~3 min at 2s intervals
    var attempts = 0;
    var msg = document.getElementById("sicoob-sso-msg");
    var timer = setInterval(function () {
      if (++attempts > maxAttempts) {
        clearInterval(timer);
        if (msg) msg.textContent = "O pedido de aprovação expirou. Tente novamente.";
        return;
      }
      fetch(pollUrl, { headers: { Accept: "application/json" } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.status === "approved") {
            clearInterval(timer);
            window.location = data.redirect_to;
          } else if (["denied", "expired", "error"].indexOf(data.status) !== -1) {
            clearInterval(timer);
            window.location = loginUrl;
          }
        })
        .catch(function () {});
    }, 2000);
  })();
</script>
